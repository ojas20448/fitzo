# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/fitzo
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fitzo
DB_USER=postgres
DB_PASSWORD=password

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=3001
NODE_ENV=development

# Cors Configuration
CORS_ORIGIN=http://localhost:19006

# AI Quota (cost control for Gemini endpoints)
# Per-user limits — requests per minute / day / calendar month
AI_BURST_LIMIT=6
AI_DAILY_LIMIT=25
AI_MONTHLY_LIMIT=150
